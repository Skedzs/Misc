-- Notification System
local NotificationHolder, Notification
pcall(function()
    NotificationHolder = loadstring(game:HttpGet("https://raw.githubusercontent.com/Skedzs/Misc/refs/heads/main/Notification/Holder"))()
    Notification = loadstring(game:HttpGet("https://raw.githubusercontent.com/Skedzs/Misc/refs/heads/main/Notification/Notif"))()
end)

local function notify(title, content, duration)
    if Notification and Notification.Notify then
        Notification:Notify({ Title = title, Description = content }, { OutlineColor = Color3.fromRGB(100, 100, 100), Time = duration or 5, Type = "default" })
    end
end

